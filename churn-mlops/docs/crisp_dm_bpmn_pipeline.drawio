        <mxCell id="leg8" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontFamily=Arial;shadow=1;rounded=1;arcSize=10;" value="" vertex="1">
          <mxGeometry height="25" width="30" x="1913" y="350" as="geometry" />
        </mxCell>
        <mxCell id="leg8t" parent="1" style="text;html=1;fontSize=11;fontFamily=Arial;" value="Evento de Início/Fim (BPMN)" vertex="1">
          <mxGeometry height="25" width="250" x="1958" y="350" as="geometry" />
        </mxCell>
        <mxCell id="ann_crisp" parent="1" style="text;html=1;strokeColor=#1e3a5f;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Arial;" value="🔄  CRISP-DM PHASES&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. Business Understanding → Raia 1&#xa;2. Data Understanding     → Raia 2 (EDA, Clustering)&#xa;3. Data Preparation       → Raia 3 (Glue ETL, Feature Store)&#xa;4. Modeling               → Raia 4 (train.py, HPO)&#xa;5. Evaluation             → Raia 5 (CI/CD, Tests)&#xa;6. Deployment             → Raia 6 (Docker, Endpoint)&#xa;7. Monitoring ★           → Raia 7 (Drift, CloudWatch)&#xa;8. Re-training Loop ★     → Raia 8 (Retreino automático)&#xa;9. RAG Integration ★      → Profile Cards → Vector Store&#xa;&#xa;★ = extensões MLOps ao CRISP-DM original" vertex="1">
          <mxGeometry height="260" width="400" x="1910" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ann_fs" parent="1" style="text;html=1;strokeColor=#b85450;fillColor=#fff0f0;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Arial;" value="🗄️  FEATURE STORE&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Offline Store (S3 Parquet)&#xa;  → Treinamento em batch&#xa;  → Reprodutibilidade garantida&#xa;&#xa;Online Store (Redis/DynamoDB)&#xa;  → Inferência em tempo real&#xa;  → Latência &lt; 20ms&#xa;&#xa;Feature Registry&#xa;  → Schema, versão, lineage&#xa;  → Statísticas de referência&#xa;  → Base para drift detection" vertex="1">
          <mxGeometry height="260" width="360" x="2318" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ann_drift" parent="1" style="text;html=1;strokeColor=#d6b656;fillColor=#fffff0;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Arial;" value="🔴  DRIFT DETECTION&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Data Drift (Feature Drift)&#xa;  → Distribuição das features mudou&#xa;  → KS Test, PSI, χ² test&#xa;  → Comparar vs snapshot do treino&#xa;&#xa;Concept Drift (Label Shift)&#xa;  → Relação X→y mudou no mundo real&#xa;  → Monitor ROC-AUC em janelas (7d/30d)&#xa;&#xa;Prediction Drift (Output Shift)&#xa;  → Taxa de churn prevista diverge&#xa;&#xa;Feature Store Drift ★&#xa;  → Stats atuais vs Feature Registry&#xa;  → Detecta inconsistências na origem" vertex="1">
          <mxGeometry height="320" width="410" x="2738" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ann_rag" parent="1" style="text;html=1;strokeColor=#ea580c;fillColor=#fffbeb;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=5;fontSize=11;fontFamily=Arial;" value="🤖  RAG INTEGRATION (★ extensão MLOps)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Saída da fase Clustering → RAG Pipeline:&#xa;&#xa;1. Profile Cards (PF/PJ)&#xa;   → label + features médias + propensão&#xa;   → aprovação BU: BUSINESS_APPROVAL ≥ 4/5&#xa;&#xa;2. Vector Store (FAISS / pgvector)&#xa;   → embeds por cluster_id + segmento&#xa;   → filtro metadata: {segmento, cluster_id}&#xa;&#xa;3. Prompt Injection&#xa;   → System Prompt: perfil + contexto RAG&#xa;   → Faithfulness ≥ 0.85 · Retrieval@5 ≥ 0.80&#xa;&#xa;Métricas: PROFILE_COVERAGE ≥ 95% · ARI ≥ 0.85&#xa;          SILHOUETTE ≥ 0.40 · DOCS ≥ 5/perfil" vertex="1">
          <mxGeometry height="310" width="420" x="3168" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ann_pf_pj" parent="1" style="text;html=1;strokeColor=#7e22ce;fillColor=#faf5ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=5;fontSize=11;fontFamily=Arial;" value="👥  SPLIT PF / PJ (Clustering canônico)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Pessoa Física (PF):&#xa;  Algoritmo: K-Means (n&gt;10k) · DBSCAN (irregular)&#xa;  Features: demográficas + comportamentais + transações&#xa;  Normalização: StandardScaler · RobustScaler (outliers)&#xa;&#xa;Pessoa Jurídica (PJ):&#xa;  Algoritmo: K-Means · Bisecting K-Means · GMM&#xa;  Features: porte + CNAE + faturamento + engajamento&#xa;  Normalização: Log-transform (faturamento/R$)&#xa;&#xa;Quality Gate Compartilhado:&#xa;  Silhouette ≥ 0.40 · CLUSTER_STABILITY_ARI ≥ 0.85&#xa;  PROFILE_COVERAGE ≥ 95% · BUSINESS_APPROVAL ≥ 4/5&#xa;  ITERATION_COUNT ≤ 5&#xa;&#xa;Gargalos monitorados:&#xa;  ⚠️ BU_WAIT_DAYS &gt; 15d → escalonar&#xa;  ⚠️ ACCESS_SLA_DAYS &gt; 10d → dados proxy" vertex="1">
          <mxGeometry height="310" width="420" x="3608" y="415" as="geometry" />
        </mxCell>
        <mxCell id="glossary_acronyms" parent="1" style="text;html=1;strokeColor=#3b82f6;fillColor=#eff6ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=5;fontSize=11;fontFamily=Arial;shadow=1;" value="&lt;div style=&quot;font-family:Arial, sans-serif; padding:12px;&quot;&gt;&lt;div style=&quot;font-size:13px; font-weight:bold; color:#1e3a5f; border-bottom:2px solid #3b82f6; padding-bottom:6px; margin-bottom:10px;&quot;&gt;📖 GLOSSÁRIO DE SIGLAS&lt;/div&gt;&lt;table style=&quot;width:100%; border-collapse:collapse; font-size:11px;&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;API&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Application Programming Interface — interface de comunicação entre serviços&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ARI&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Adjusted Rand Index — estabilidade de clustering (meta ≥ 0.85)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;AWS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Amazon Web Services — plataforma de cloud computing&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;BPMN&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Business Process Model and Notation — notação padrão de processos&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;BU&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Business Unit — área de negócio responsável pela aprovação dos clusters&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;CNAE&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Classificação Nacional de Atividades Econômicas — feature de segmentação PJ&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;CRISP&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Cross-Industry Standard Process — base da metodologia CRISP-DM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;CRM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Customer Relationship Management — sistema de gestão de relacionamento&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;DBSCAN&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Density-Based Spatial Clustering — algoritmo para formas irregulares&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;EDA&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Exploratory Data Analysis — análise exploratória dos dados&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ETL&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Extract, Transform, Load — pipeline de ingestão de dados (AWS Glue)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;FAISS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Facebook AI Similarity Search — biblioteca de busca vetorial eficiente&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;GBM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Gradient Boosting Machine — modelo de classificação de churn (sklearn)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;GMM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Gaussian Mixture Model — clustering probabilístico (soft assignment)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;HPO&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Hyperparameter Optimization — tuning de hiperparâmetros (SM / GridSearch)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PF&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Pessoa Física — segmento de clientes individuais&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PJ&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Pessoa Jurídica — segmento de clientes empresariais&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PSI&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Population Stability Index — detecção de drift em distribuições de features&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;RAG&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Retrieval-Augmented Generation — geração de texto com contexto recuperado&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;RDS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Relational Database Service — banco de dados gerenciado (AWS)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ROC&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Receiver Operating Characteristic — Área sob a curva (meta ≥ 0.70)&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="304" width="3980" x="42" y="1742" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
