        <mxCell id="mt_data_body" value="&lt;table style=&quot;width:100%; border-collapse:collapse; font-family:'Inter', sans-serif; font-size:12px;&quot;&gt;&lt;thead&gt;&lt;tr style=&quot;background-color:#fef9c3; border-bottom:2px solid #eab308; color:#713f12;&quot;&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Métrica&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Segmento&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Meta&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Alerta&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr style=&quot;border-bottom:1px solid #fef08a;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;DATA_COMPLETENESS(%)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#a16207; font-size:10px;&quot;&gt;Proporção de campos não-nulos por linha&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;PF / PJ&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 80%&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 60%&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fef08a;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;OUTLIER_RATE(%)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#a16207; font-size:10px;&quot;&gt;% registros fora de range (IQR / 3σ)&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Ambos&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;&amp;lt; 5%&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;gt; 15%&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fef08a;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;FEATURE_COVERAGE(%)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#a16207; font-size:10px;&quot;&gt;% features do schema esperado no dataset real&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Ambos&lt;/td&gt;&lt;td style=&quot;padding