        <mxCell id="mt_ttm_body" value="&lt;table style=&quot;width:100%; border-collapse:collapse; font-family:'Inter', sans-serif; font-size:12px;&quot;&gt;&lt;thead&gt;&lt;tr style=&quot;background-color:#dbeafe; border-bottom:2px solid #3b82f6; color:#1e3a8a;&quot;&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Métrica&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Freq.&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Meta&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Alerta&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr style=&quot;border-bottom:1px solid #bfdbfe;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;TIME_TO_FIRST_CLUSTER&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#1e40af; font-size:10px;&quot;&gt;Dias até fechar modelo inicial&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Projeto&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≤ 30 dias&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;gt; 60 dias&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #bfdbfe;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;TIME_TO_RAG_READY&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#1e40af; font-size:10px;&quot;&gt;Dias de documentação e injeção do RAG&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Projeto&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≤ 15 dias&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;gt; 30 dias&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #bfdbfe;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;BACKLOG_DELAY_RATIO(%)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#1e40af; font-size:10px;&quot;&gt;Atraso em backlog tasks&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Semanal&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;&amp;lt; 10%&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;gt; 30%&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #bfdbfe;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;KNOWLEDGE_GAP_SCORE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#1e40af; font-size:10px;&quot;&gt;Dúvidas não sanadas (bloqueia avanço)&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Projeto&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;= 0&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;gt; 0&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;" vertex="1" parent="1">
