        <mxCell id="mt_rag_body" value="&lt;table style=&quot;width:100%; border-collapse:collapse; font-family:'Inter', sans-serif; font-size:12px;&quot;&gt;&lt;thead&gt;&lt;tr style=&quot;background-color:#ffedd5; border-bottom:2px solid #f97316; color:#7c2d12;&quot;&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Métrica&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Escopo&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Meta&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Alerta&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr style=&quot;border-bottom:1px solid #fed7aa;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;RAG_DOC_QUALITY_SCORE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#9a3412; font-size:10px;&quot;&gt;Qualidade humana do doc de negócio&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Perfil&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 4.0/5&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 3.0/5&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fed7aa;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;PROMPT_RETRIEVAL_RECALL@5&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#9a3412; font-size:10px;&quot;&gt;Taxa de acerto de documentos no RAG&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;PF / PJ&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 0.80&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 0.60&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fed7aa;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;CONTEXT_PRECISION&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#9a3412; font-size:10px;&quot;&gt;Precisão vs ruído do contexto injetado&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Consulta&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 0.75&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 0.50&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fed7aa;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;FAITHFULNESS_SCORE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#9a3412; font-size:10px;&quot;&gt;Nível de ausência de alucinação do LLM&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Consulta&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 0.85&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 0.70&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #fed7aa;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;PROFILE_TOTAL_DOCS&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#9a3412; font-size:10px;&quot;&gt;Qtde. de docs base para inferir sobre o RAG&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;PF / PJ&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 5 docs&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 3 docs&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;" vertex="1" parent="1">
