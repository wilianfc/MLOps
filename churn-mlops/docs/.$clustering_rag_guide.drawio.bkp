        <!-- Segunda coluna: guia algoritmos + templates -->
        <mxCell id="algo_guide" value="&lt;div style=&quot;padding:12px; font-family:'Inter', sans-serif;&quot;&gt;&lt;h3 style=&quot;margin-top:0; margin-bottom:12px; color:#15803d;&quot;&gt;GUIA DE SELEÇÃO DE ALGORITMOS&lt;/h3&gt;&lt;table style=&quot;width:100%; border-collapse:collapse; font-size:11px; margin-bottom:16px;&quot;&gt;&lt;thead&gt;&lt;tr style=&quot;border-bottom:2px solid #bbf7d0; text-align:left; color:#14532d;&quot;&gt;&lt;th style=&quot;padding:6px;&quot;&gt;DADO&lt;/th&gt;&lt;th style=&quot;padding:6px;&quot;&gt;RECOMENDADO&lt;/th&gt;&lt;th style=&quot;padding:6px;&quot;&gt;POR QUÊ&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Tabular, n&amp;gt;10k&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;K-Means&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Escala rápido e interpretável&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Tabular, n&amp;lt;5k&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;Agglomerative&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Dendrograma para grupos&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Tabular misto&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;K-Prototypes&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Numérico + categórico nativo&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Forma irregular&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;DBSCAN&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Não assume esfericidade&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Gaussiano&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;GMM&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Probabilidade de pertinência&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #dcfce7;&quot;&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Hierar. PJ&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;&lt;b&gt;Bisecting K-Means&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:6px;&quot;&gt;Segmentação top-down&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;ul style=&quot;font-size:11px; padding-left:20px; color:#166534; line-height:1.6; margin:0;&quot;&gt;&lt;li&gt;&lt;b&gt;Seleção de K:&lt;/b&gt; Elbow + Silhouette + Davies-Bouldin. &lt;u&gt;Sempre validar com expert.&lt;/u&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Normalização:&lt;/b&gt; StandardScaler. RobustScaler (para PJ / Outliers). Log-transform (para faturamento/R$).&lt;/li&gt;&lt;li&gt;&lt;b&gt;Features PF:&lt;/b&gt; Demográficas, comportamentais, transações.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Features PJ:&lt;/b&gt; Porte, setor CNAE, faturamento, engajamento.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;strokeColor=#16a34a;fillColor=#f0fdf4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=10;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="2920" y="320" width="790" height="430" as="geometry" />
        </mxCell>
        <mxCell id="profile_template" value="&lt;div style=&quot;padding:16px; font-family:'Inter', sans-serif; color:#4c1d95;&quot;&gt;&lt;h3 style=&quot;margin-top:0; color:#7e22ce; border-bottom:2px solid #d8b4fe; padding-bottom:8px;&quot;&gt;🗒️ TEMPLATE DE PROFILE CARD&lt;/h3&gt;&lt;h4 style=&quot;margin:12px 0 8px 0; color:#581c87;&quot;&gt;Perfil: [LABEL INTERPRETÁVEL]&lt;/h4&gt;&lt;div style=&quot;background:#f3e8ff; padding:10px; border-radius:6px; font-size:11px; margin-bottom:12px;&quot;&gt;&lt;b&gt;Segmento:&lt;/b&gt; PF / PJ &amp;nbsp;|&amp;nbsp; &lt;b&gt;Cluster ID:&lt;/b&gt; N &amp;nbsp;|&amp;nbsp; &lt;b&gt;Base:&lt;/b&gt; XX%&lt;/div&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;Características Centrais:&lt;/b&gt;&lt;ul style=&quot;margin:6px 0 12px 0; padding-left:20px; font-size:11px; line-height:1.4;&quot;&gt;&lt;li&gt;Feature 1: valor médio ± desvio&lt;/li&gt;&lt;li&gt;Feature 2: valor médio ± desvio&lt;/li&gt;&lt;li&gt;Feature N: valor médio ± desvio&lt;/li&gt;&lt;/ul&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;Comportamento Típico:&lt;/b&gt;&lt;div style=&quot;font-size:11px; margin:6px 0 12px 0; color:#6b21a8; font-style:italic;&quot;&gt;&amp;quot;[Descrição validada com stakeholder de negócio]&amp;quot;&lt;/div&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;Produtos Associados:&lt;/b&gt;&lt;ul style=&quot;margin:6px 0 12px 0; padding-left:20px; font-size:11px;&quot;&gt;&lt;li&gt;Produto A (freq: XX%) &amp;nbsp;|&amp;nbsp; Produto B (freq: XX%)&lt;/li&gt;&lt;/ul&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;Propensão:&lt;/b&gt;&lt;div style=&quot;font-size:11px; margin:6px 0 12px 0;&quot;&gt;Churn: XX% &amp;nbsp;|&amp;nbsp; Cross-sell: XX%&lt;/div&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;Abordagem Recomendada:&lt;/b&gt;&lt;div style=&quot;font-size:11px; margin:6px 0 16px 0;&quot;&gt;[Ação sugerida pelo negócio]&lt;/div&gt;&lt;div style=&quot;margin-top:16px; font-size:11px; border-top:1px dashed #d8b4fe; padding-top:12px;&quot;&gt;&lt;b&gt;Aprovação:&lt;/b&gt; DS: _________ &amp;nbsp; PO: _________ &amp;nbsp; Data: _________&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=#a855f7;fillColor=#faf5ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=10;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="2920" y="770" width="790" height="490" as="geometry" />
        </mxCell>
        <mxCell id="rag_prompt_guide" value="&lt;div style=&quot;padding:16px; font-family:'Inter', sans-serif; color:#9a3412;&quot;&gt;&lt;h3 style=&quot;margin-top:0; color:#ea580c; border-bottom:2px solid #fed7aa; padding-bottom:8px;&quot;&gt;🤖 TEMPLATE DE PROMPT RAG&lt;/h3&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;System Prompt (Injetado):&lt;/b&gt;&lt;div style=&quot;background:#ffedd5; padding:12px; border-radius:6px; font-size:11px; margin:8px 0 16px 0; font-family:monospace; line-height:1.5;&quot;&gt;Você é um assistente especializado em [domínio].&lt;br&gt;O cliente possui o seguinte perfil:&lt;br&gt;&lt;br&gt;&lt;b&gt;Segmento:&lt;/b&gt; {pf_ou_pj}&lt;br&gt;&lt;b&gt;Perfil:&lt;/b&gt; {label_do_cluster}&lt;br&gt;&lt;b&gt;Características:&lt;/b&gt; {features_resumidas}&lt;br&gt;&lt;br&gt;Use apenas as informações do contexto abaixo. Se não souber, diga que não sabe.&lt;br&gt;&lt;br&gt;&lt;b&gt;Contexto recuperado:&lt;/b&gt;&lt;br&gt;{top_k_chunks_do_vector_store}&lt;/div&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;User Prompt:&lt;/b&gt;&lt;div style=&quot;background:#ffedd5; padding:12px; border-radius:6px; font-size:11px; margin:8px 0 16px 0; font-family:monospace;&quot;&gt;{pergunta_do_usuário}&lt;/div&gt;&lt;div style=&quot;font-size:11px; border-top:1px dashed #fed7aa; padding-top:12px;&quot;&gt;&lt;b style=&quot;color:#c2410c;&quot;&gt;🔍 METADADOS DE FILTRO NO VECTOR STORE:&lt;/b&gt;&lt;ul style=&quot;margin:8px 0 0 0; padding-left:20px; line-height:1.5;&quot;&gt;&lt;li&gt;segmento: 'PF' | 'PJ'&lt;/li&gt;&lt;li&gt;cluster_id: N&lt;/li&gt;&lt;li&gt;doc_type: 'perfil' | 'produto' | 'faq'&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=#ea580c;fillColor=#fffbeb;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=10;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="2920" y="1280" width="790" height="490" as="geometry" />
        </mxCell>

