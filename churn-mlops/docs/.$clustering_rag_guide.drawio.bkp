        <mxCell id="mt_cl_body" value="&lt;table style=&quot;width:100%; border-collapse:collapse; font-family:'Inter', sans-serif; font-size:12px;&quot;&gt;&lt;thead&gt;&lt;tr style=&quot;background-color:#dcfce7; border-bottom:2px solid #22c55e; color:#14532d;&quot;&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Métrica&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Segmento&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Meta&lt;/th&gt;&lt;th style=&quot;padding:8px; text-align:left;&quot;&gt;Alerta&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr style=&quot;border-bottom:1px solid #bbf7d0;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;SILHOUETTE_SCORE&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#166534; font-size:10px;&quot;&gt;Mede coesão vs separação [-1, 1]&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;PF / PJ&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 0.40&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 0.25&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #bbf7d0;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;CLUSTER_STABILITY_ARI&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#166534; font-size:10px;&quot;&gt;ARI em 10 execuções bootstrap&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;PF / PJ&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≥ 0.85&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#ef4444; font-weight:bold;&quot;&gt;&amp;lt; 0.60&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-bottom:1px solid #bbf7d0;&quot;&gt;&lt;td style=&quot;padding:8px;&quot;&gt;&lt;b&gt;ITERATION_COUNT&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#166534; font-size:10px;&quot;&gt;Rodadas até atingir métricas&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;padding:8px;&quot;&gt;Ambos&lt;/td&gt;&lt;td style=&quot;padding:8px; color:#16a34a;&quot;&gt;≤ 5&l