        <mxCell id="e_rag1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f97316;fontFamily=Arial;strokeWidth=2;" edge="1" source="ecs_rag_route" target="ecs_vector_store" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ann_rag_aws" parent="1" style="text;html=1;strokeColor=#ea580c;fillColor=#fffbeb;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=5;fontSize=11;fontFamily=Arial;" value="🤖  RAG INTEGRATION — Rotas e Artefatos&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Nova rota: POST /rag/query&#xa;  Input:  {cluster_id, segmento, pergunta}&#xa;  Lookup: Vector Store (FAISS/pgvector)&#xa;  Filtro metadata: segmento + cluster_id&#xa;  Output: resposta LLM + docs recuperados&#xa;&#xa;Artefatos S3 adicionais:&#xa;  profile_cards.json  → label, features, propensão&#xa;  cluster_profiles/   → docs .md por cluster (base RAG)&#xa;&#xa;Response /predict ampliado:&#xa;  + cluster_id · perfil_label · segmento (PF|PJ)&#xa;&#xa;Métricas RAG monitoradas no CloudWatch:&#xa;  Faithfulness ≥ 0.85 · Retrieval@5 ≥ 0.80&#xa;  ContextPrecision ≥ 0.75 · Docs/perfil ≥ 5" vertex="1">
          <mxGeometry height="290" width="440" x="2080" y="870" as="geometry" />
        </mxCell>
        <mxCell id="glossary_acronyms" parent="1" style="text;html=1;strokeColor=#3b82f6;fillColor=#eff6ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=5;fontSize=11;fontFamily=Arial;shadow=1;" value="&lt;div style=&quot;font-family:Arial, sans-serif; padding:12px;&quot;&gt;&lt;div style=&quot;font-size:13px; font-weight:bold; color:#1e3a5f; border-bottom:2px solid #3b82f6; padding-bottom:6px; margin-bottom:10px;&quot;&gt;📖 GLOSSÁRIO DE SIGLAS&lt;/div&gt;&lt;table style=&quot;width:100%; border-collapse:collapse; font-size:11px;&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ALB&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Application Load Balancer — balanceador de carga HTTP/HTTPS (AWS)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;API&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Application Programming Interface — interface de comunicação entre serviços&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ARN&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Amazon Resource Name — identificador único de recurso AWS&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ASGI&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Asynchronous Server Gateway Interface — padrão async Python (uvicorn)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;AWS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Amazon Web Services — plataforma de cloud computing&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;DAG&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Directed Acyclic Graph — grafo de orquestração (SageMaker Pipelines)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ECR&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Elastic Container Registry — registro de imagens Docker (AWS)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ECS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Elastic Container Service — orquestração de containers Fargate (AWS)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;EDA&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Exploratory Data Analysis — análise exploratória dos dados&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ETL&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Extract, Transform, Load — pipeline de ingestão de dados (AWS Glue)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;FAISS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Facebook AI Similarity Search — biblioteca de busca vetorial eficiente&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;GBM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Gradient Boosting Machine — modelo de classificação de churn (sklearn)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;IAM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Identity and Access Management — controle de permissões AWS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;LLM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Large Language Model — modelo de linguagem (ex.: GPT, Claude, Gemini)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PCA&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Principal Component Analysis — redução de dimensionalidade para visualização&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PF&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Pessoa Física — segmento de clientes individuais&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;PJ&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Pessoa Jurídica — segmento de clientes empresariais&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;RAG&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Retrieval-Augmented Generation — geração de texto com contexto recuperado&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;ROC&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Receiver Operating Characteristic — Área sob a curva (meta ≥ 0.70)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;SDK&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; border-right:1px solid #e2e8f0;&quot;&gt;Software Development Kit — kit de desenvolvimento (ex.: boto3, sagemaker)&lt;/td&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;SNS&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Simple Notification Service — serviço de alertas e notificações (AWS)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8fafc;&quot;&gt;&lt;td style=&quot;padding:4px 8px; font-weight:bold; color:#1e40af; white-space:nowrap;&quot;&gt;WORM&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;Write Once Read Many — política de S3 Object Lock para auditoria imutável&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="336" width="2600" x="40" y="1330" as="geometry" />
        </mxCell>
