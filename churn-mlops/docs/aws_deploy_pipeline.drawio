        <!-- AWS SERVICES TABLE -->
        <mxCell id="aws_table" value="AWS SERVICES — RESPONSABILIDADES&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Amazon ECR         Registry de imagens Docker&#xa;Amazon S3          Artefatos (model.pkl, Parquet, PNGs)&#xa;AWS Glue           ETL PySpark Serverless&#xa;SageMaker Training Training Job gerenciado&#xa;SageMaker Pipeline DAG de steps (ETL→Train→Eval→Register)&#xa;SageMaker Registry Versionamento e aprovação de modelos&#xa;SageMaker Endpoint Inferência gerenciada (ml.t3.medium)&#xa;SageMaker Monitor  DataQualityJob + drift baseline&#xa;AWS Lambda         Proxy boto3 → SM Endpoint&#xa;API Gateway        REST API pública com Auth&#xa;ECS Fargate        Container FastAPI serverless&#xa;ALB                Load Balancer HTTPS + health check&#xa;CloudWatch Metrics Latência, erros, throughput&#xa;CloudWatch Logs    Logs estruturados da API&#xa;CloudWatch Alarms  Threshold → SNS → alertas&#xa;Amazon SNS         Notificações (email/Slack/PagerDuty)&#xa;EventBridge        Scheduler → trigger retreino automático&#xa;IAM Roles          Permissões mínimas por serviço" style="text;html=1;strokeColor=#007bff;fillColor=#f0f8ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="2640" y="840" width="550" height="470" as="geometry" />
        </mxCell>

          <mxCell id="ecs_rag_route" value="FastAPI&#xa;POST /rag/query&#xa;{cluster_id, segmento,&#xa; pergunta}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#f97316;fontSize=10;fontFamily=Arial;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1400" y="870" width="150" height="70" as="geometry" />
