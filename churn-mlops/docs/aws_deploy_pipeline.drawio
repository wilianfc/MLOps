        <mxCell id="ecs_vector_store" value="Vector Store&#xa;FAISS / pgvector&#xa;filtro: segmento&#xa;+ cluster_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#f97316;fontSize=10;fontFamily=Arial;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1580" y="870" width="150" height="70" as="geometry" />
